# ── Mock mode ────────────────────────────────────────────────────────────────
# Set both to true to run the app fully locally (no Supabase/Stripe required).
MOCK_MODE=true
NEXT_PUBLIC_MOCK_MODE=true

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Supabase (required when MOCK_MODE=false) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# ── Database (Prisma / Supabase Postgres) ────────────────────────────────────
# Pooled connection (runtime) and direct connection (migrations).
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── Stripe billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER_MONTHLY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH_MONTHLY=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH_ANNUAL=price_xxxxxxxxxxxxxxxx

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_ADDRESS=Klover <noreply@example.com>

# ── Error monitoring (Sentry, optional) ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Security ─────────────────────────────────────────────────────────────────
# 32+ char random string used to encrypt stored integration credentials.
# Generate one with: openssl rand -base64 32
KLOVER_ENCRYPTION_KEY=
